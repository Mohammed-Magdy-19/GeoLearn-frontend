    "version": 2,
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/api/:match*",
            "destination": "https://railway.app*"
        },
        {
            "source": "/((?!assets/|robots\\.txt|sitemap\\.xml|favicon\\.svg|icons\\.svg).*)",
            "destination": "/index.html"
        }
    ]
}